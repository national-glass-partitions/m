RewriteEngine on

# Block fake AMP URLs - return 410 Gone
RewriteCond %{QUERY_STRING} ^amp=1$ [NC]
RewriteRule ^ - [G,L]

# Block spam searches (foreign characters, forex spam) - allow legitimate searches
RewriteCond %{REQUEST_URI} ^/catalogsearch/result/ [NC]
RewriteCond %{QUERY_STRING} q=.*(%D|%E|%F|%B|%C|%A|\[Tg:) [NC,OR]
RewriteCond %{QUERY_STRING} q=.*(forex|broker|MT4|telegram|bitcoin|trading|casino) [NC]
RewriteRule ^ - [G,L]

# Block login referer URLs - return 410 Gone
RewriteCond %{REQUEST_URI} ^/customer/account/login/referer/ [NC]
RewriteRule ^ - [G,L]

# Block category pages with excessive filter parameters - return 410 Gone
RewriteCond %{QUERY_STRING} (depth|panel_height|door_height|width|colour|price|glass_type|partition_type)= [NC]
RewriteCond %{QUERY_STRING} .{100,}
RewriteRule ^ - [G,L]

RewriteCond %{REQUEST_URI} !^/pub/
RewriteCond %{REQUEST_URI} !^/setup/
RewriteCond %{REQUEST_URI} !^/update/
RewriteCond %{REQUEST_URI} !^/dev/
RewriteRule .* /pub/$0 [L]
DirectoryIndex index.php