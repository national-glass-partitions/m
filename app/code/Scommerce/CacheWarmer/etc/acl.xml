 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                
               
                
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="Scommerce_CacheWarmer::config_cachewarmer" title="Scommerce Cache Warmer Section" sortOrder="60" />
                        </resource>
                    </resource>
                </resource>
                
                
                 <resource id="Magento_Backend::system">
                    <resource id="Scommerce_CacheWarmer::cachewarmer" title="Cache Warmer Menu" sortOrder="511">
                        <resource id="Scommerce_CacheWarmer::cachewarmer_manage" title="Cache Warmer Item" sortOrder="110"/>
                        <resource id="Scommerce_CacheWarmer::cachewarmer_delete" title="Cache Warmer Delete" sortOrder="120"/>
                    </resource>
                </resource>
                
              <!--<resource id="Magento_Backend::tools" title="Tools" translate="title" sortOrder="50">
                        <resource id="Magento_Backend::cache" title="Cache Management111" translate="title"  sortOrder="10">
                        </resource>
                </resource>-->
                
                
                
                
                
                
                
                
                
                
                
                
            </resource>
        </resources>
    </acl>
</config>


