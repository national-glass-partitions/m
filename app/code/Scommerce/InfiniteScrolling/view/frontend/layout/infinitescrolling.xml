<?xml version="1.0"?>
<!--
/**
 * Scommerce InfiniteScrolling layout
 
 * @category   Scommerce
 * @package    Scommerce_InfiniteScrolling
 * @author     Scommerce Mage <core@scommerce-mage.com>
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="Scommerce_InfiniteScrolling::css/style.css" />
    </head>
    <body>
        <referenceContainer name="page.wrapper">
            <block class="Scommerce\InfiniteScrolling\Block\Infobar"
                   name="infobar.list.footer"
                   template="infobar.phtml"
                   before="page-footer">
            </block>
        </referenceContainer>
            <referenceContainer name="content">
            <block class="Scommerce\InfiniteScrolling\Block\Initialize" name="infinitescrolling.initialize" template="Scommerce_InfiniteScrolling::initialize.phtml"/>
        </referenceContainer>
    </body>
</page>
