<?xml version="1.0"?>
<!--
/**
 * Scommerce Mage Image Optimiser for di xml
 * @category   Scommerce
 * @package    Scommerce_ImageOptimiser
 * @author     Scommerce Mage <core@scommerce-mage.com>
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
  
    <!-- Hitting cron file by command line -->
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="mediabackup" xsi:type="object">Scommerce\ImageOptimiser\Console\Command\MediaBackup</item>
            </argument>
        </arguments>
    </type>
    <!-- Log generation process -->
    <type name="Scommerce\ImageOptimiser\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Scommerce\ImageOptimiser\Logger\Logger">
       <arguments>
        <argument name="name"      xsi:type="string">Scommerce/ImageOptimiser</argument>
        <argument name="handlers"  xsi:type="array">
            <item name="debug"     xsi:type="object">Scommerce\ImageOptimiser\Logger\Handler</item>
        </argument>
       </arguments>   
    </type>
     <!-- Image compression for wysiwyg -->
    <type name="Magento\Cms\Model\Wysiwyg\Images\Storage">
        <plugin name="scommerce_imageoptimiser_cms_wysiwyg_uploader_save_file"
                type="Scommerce\ImageOptimiser\Plugin\Cms\Model\Wysiwyg\Images\StoragePlugin"
                sortOrder="1" disabled="false" />
    </type>
    <!-- Image compression for category image -->
    <type name="Magento\Catalog\Model\ImageUploader">
        <plugin name="scommerce_imageoptimiser_catalog_category_uploader_save_file"
                type="Scommerce\ImageOptimiser\Plugin\Catalog\Model\ImageUploader\ImageUploaderPlugin"
                sortOrder="1" disabled="false" />
    </type>
    <!-- Image compression for product image -->
    <type name="Magento\Catalog\Controller\Adminhtml\Product\Save">
        <plugin name="scommerce_imageoptimiser_catalog_product_uploader_save_file"
                type="Scommerce\ImageOptimiser\Plugin\Catalog\Model\Product\Image\ImagePlugin"
                sortOrder="1" disabled="false" />
    </type>

</config>